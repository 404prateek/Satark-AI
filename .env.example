# =============================================================================
# Satark AI — Single Source of Truth for Environment Variables
# =============================================================================

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string (asyncpg async driver for FastAPI)
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/satark_ai

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=change-me-in-production-use-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Google OAuth 2.0 ─────────────────────────────────────────────────────────
# Create credentials at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must be registered in Google Cloud Console under "Authorized redirect URIs"
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# ── AI / LLM ──────────────────────────────────────────────────────────────────
# Free API key from: https://console.groq.com
GROQ_API_KEY=

# ── URL Analysis ─────────────────────────────────────────────────────────────
# Free API key from: https://www.phishtank.com/api_register.php
PHISHTANK_API_KEY=

# Google Safe Browsing API v4
# Free via: https://console.cloud.google.com → APIs & Services → Enable "Safe Browsing API"
# Free tier: 10,000 requests/day — no per-minute rate limit.
# Upgrade needed at: https://cloud.google.com/safe-browsing/pricing
GOOGLE_SAFE_BROWSING_API_KEY=

# VirusTotal URL Reputation API v3
# Free via: https://www.virustotal.com/gui/join-us
# Free tier: 4 requests/minute, 500 requests/day.
# Rate limiting is handled automatically by an asyncio Semaphore in reputation_sources.py.
# Upgrade needed at: https://www.virustotal.com/gui/premium-services/overview
VIRUSTOTAL_API_KEY=


# ── Model ────────────────────────────────────────────────────────────────────
# Absolute or relative path to the trained phishing classifier pickle
MODEL_PATH=./data/model.pkl

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=Satark AI
APP_VERSION=1.0.0
DEBUG=false

# ── Frontend (Vite — prefix VITE_ is required to expose to browser) ───────────
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_GOOGLE_CLIENT_ID=
VITE_APP_NAME=Satark AI

ARMORIQ_API_KEY=
OPENAI_API_KEY=
